# Copier vers .env.local : cp .env.example .env.local
# ⚠️ .env.local n'est JAMAIS versionné (voir .gitignore)

# --- App ---
# ⚠️ En production : définir https://jurivite.fr AVANT npm run build (canonical, sitemap, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mentions légales site (LCEN — hébergeur VPS) ---
JURIVITE_HOSTING_PROVIDER=
JURIVITE_HOSTING_ADDRESS=
JURIVITE_CONTACT_EMAIL=contact@jurivite.fr
JURIVITE_PUBLISHER_FULL_NAME=Benjamin Boyer
JURIVITE_DIRECTOR_NAME=Benjamin Boyer — fondateur et directeur de publication
JURIVITE_PRIVACY_EMAIL=contact@jurivite.fr
# Présence en ligne (optionnel — JSON-LD, page À propos)
# JURIVITE_PUBLISHER_WEBSITE=
# JURIVITE_LINKEDIN_URL=
# JURIVITE_GITHUB_URL=
# JURIVITE_MEDIATOR_NAME=
# JURIVITE_MEDIATOR_URL=

# --- Auth.js (les deux alias fonctionnent) ---
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- PostgreSQL (npm run db:up puis npm run db:push) ---
DATABASE_URL=postgresql://jurivite:secret@localhost:5432/jurivite

# --- Google OAuth (optionnel) ---
# https://console.cloud.google.com/ → redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend — magic link (optionnel en local) ---
# Sans domaine vérifié : utiliser onboarding@resend.dev comme EMAIL_FROM
# Limite : envoi uniquement vers l'email de ton compte Resend
RESEND_API_KEY=
EMAIL_FROM=JuriVite <onboarding@resend.dev>

# --- Stripe mode test — 2 abonnements ---
# Pro 9€/mois (20 PDF) + Business 30€/mois (illimité + API)
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_PRICE_ID_PRO=price_
STRIPE_PRICE_ID_BUSINESS=price_

# --- Observabilité (production) ---
# https://sentry.io — alertes Slack/Email sur erreurs PDF, Stripe, API
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# --- Back-office admin (e-mails autorisés, séparés par des virgules) ---
ADMIN_EMAILS=

# --- PDF (production VPS) ---
# PDF_WARM_ON_START=1
# PDF_MAX_CONCURRENT=2
# Conteneur Docker isolé uniquement — jamais sur VPS bare metal :
# PDF_CHROME_NO_SANDBOX=1

# --- Rate limiting multi-instances (Upstash Redis) ---
# Si définis, remplace le store mémoire du middleware
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- HSTS en staging HTTPS ---
# FORCE_HSTS=1

# --- Backups (scripts/backup-postgres.sh) ---
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=14
# S3_BUCKET=s3://jurivite-backups
